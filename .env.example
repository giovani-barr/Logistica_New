# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (SQLite defaut, descomente par PostgreSQL)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=logistica_db
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# OSRM Router (Leave default for public instance)
OSRM_ROUTER_URL=https://router.project-osrm.org/route/v1

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.instagram.com/v18.0/
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Security (Change for production)
CSRF_TRUSTED_ORIGINS=localhost,127.0.0.1
